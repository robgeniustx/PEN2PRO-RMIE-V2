# XLR8 Frontend — Vite Environment Variables
# Copy to .env and fill in your values.
# Variables must start with VITE_ to be exposed to the browser.

# Your FastAPI backend URL (no trailing slash)
VITE_API_URL=https://your-api.onrender.com

# Google Analytics 4 Measurement ID
# Find at: GA4 → Admin → Data Streams → your stream → Measurement ID
VITE_GA4_ID=G-XXXXXXXXXX

# Optional: direct webhook URL for owner notifications
# Leave blank if using VITE_API_URL/api/notifications/owner
VITE_OWNER_WEBHOOK_URL=
