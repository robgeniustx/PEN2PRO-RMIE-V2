# XLR8 Pressure Washing Services — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Admin Protection ─────────────────────────────────────────────────────────
# Choose a long random string. Keep private.
ADMIN_ACCESS_KEY=xlr8-admin-secret-key-change-this

# ── Notifications ────────────────────────────────────────────────────────────
OWNER_EMAIL=info@xlr8pws.com
OWNER_PHONE=+18324595981

# ── SendGrid (email notifications) ──────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@xlr8pws.com

# ── Twilio (SMS notifications — optional) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (development):
DATABASE_URL=sqlite:///./xlr8.db
# Production PostgreSQL on Render (example):
# DATABASE_URL=postgresql://xlr8_user:password@hostname/xlr8_db

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://xlr8pws.com
