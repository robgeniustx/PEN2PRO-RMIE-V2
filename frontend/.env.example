# =============================================================
# PEN2PRO BusinessOS — Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All keys MUST start with VITE_ to be exposed to the browser.
# DO NOT commit .env to version control.
# =============================================================

# ─── API ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── App Identity ─────────────────────────────────────────────
VITE_APP_NAME=PEN2PRO
VITE_APP_TAGLINE=Rapid Monetization Intelligence Engine
VITE_LAUNCH_DATE=2026-06-10

# ─── Stripe (Publishable Key Only — never put secret key here) ─
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Feature Flags ────────────────────────────────────────────
VITE_PAYMENTS_LIVE=false
VITE_VOICE_AGENT_ENABLED=true
VITE_WEBSITE_BUILDER_ENABLED=true
VITE_COMMAND_CENTER_ENABLED=true
VITE_SHOW_AGENCY_PLAN=true

# ─── Analytics & Tracking ─────────────────────────────────────
VITE_GOOGLE_ANALYTICS_ID=
VITE_META_PIXEL_ID=
VITE_GOOGLE_ADS_CONVERSION_ID=
VITE_GOOGLE_ADS_CONVERSION_LABEL=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Google ───────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_MAPS_API_KEY=

# ─── Affiliate Links ──────────────────────────────────────────
VITE_AFFILIATE_LLC_URL=https://www.zenbusiness.com/?affiliate=pen2pro
VITE_AFFILIATE_BANKING_URL=https://mercury.com/?r=pen2pro
VITE_AFFILIATE_CREDIT_URL=https://nav.com/?affiliate=pen2pro
VITE_AFFILIATE_FUNDING_URL=https://fundbox.com/?affiliate=pen2pro
VITE_AFFILIATE_DOMAIN_URL=https://namecheap.pxf.io/pen2pro
VITE_AFFILIATE_BOOKKEEPING_URL=https://wave.com/?affiliate=pen2pro
VITE_AFFILIATE_PAYMENT_URL=https://stripe.com/?affiliate=pen2pro
VITE_AFFILIATE_CRM_URL=https://hubspot.com/?affiliate=pen2pro
VITE_AFFILIATE_INSURANCE_URL=https://nextinsurance.com/?affiliate=pen2pro
VITE_AFFILIATE_MARKETING_URL=https://mailchimp.com/?affiliate=pen2pro

# ─── Domain / Namecheap ───────────────────────────────────────
VITE_NAMECHEAP_AFFILIATE_ID=
VITE_DOMAIN_AFFILIATE_URL=https://namecheap.pxf.io/pen2pro

# ─── Cloudflare ───────────────────────────────────────────────
# Note: Do not put CLOUDFLARE_API_TOKEN here — backend only.
# Frontend only needs the zone/analytics ID if using Cloudflare Web Analytics.
VITE_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# ─── Social / Community ───────────────────────────────────────
VITE_FACEBOOK_APP_ID=
VITE_TWITTER_HANDLE=pen2pro
