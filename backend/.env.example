# =============================================================
# PEN2PRO BusinessOS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================

# ─── App Identity ─────────────────────────────────────────────
APP_NAME=PEN2PRO BusinessOS
APP_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─── AI / OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
OPENAI_MODEL_BLUEPRINT=gpt-4o-mini
OPENAI_MODEL_VOICE=gpt-4o-mini

# ─── Voyage AI (Vector Embeddings + Reranking) ────────────────
# Get your key at: https://www.voyageai.com
# Used for: RMIE knowledge base semantic search + reranking
# Embedding model: voyage-large-2-instruct (1536-dim)
# Reranking model: rerank-2
VOYAGE_API_KEY=

# ─── MongoDB Atlas Vector Search ──────────────────────────────
# After seeding, create a Vector Search index in Atlas UI:
#   Collection:    rmie_knowledge
#   Index name:    rmie_knowledge_vector_index
#   Type:          vectorSearch
#   Path:          embedding
#   numDimensions: 1536
#   Similarity:    cosine
VECTOR_SEARCH_INDEX=rmie_knowledge_vector_index

# ─── Database (MongoDB) ───────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=pen2pro_rmie

# ─── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Google OAuth & APIs ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_CALENDAR_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_BUSINESS_PROFILE_API_KEY=
GOOGLE_ANALYTICS_ID=

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ELITE_MONTHLY=
STRIPE_PRICE_FOUNDERS=
STRIPE_PRICE_FOUNDER_ONETIME=
STRIPE_PRICE_FOUNDERS_LIFETIME=
STRIPE_PRICE_AGENCY_MONTHLY=

# ─── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ─── ElevenLabs AI Voice Agent ───────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_AGENT_ID=

# ─── Email — SendGrid ─────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@pen2pro.com
SENDGRID_TEMPLATE_WELCOME=
SENDGRID_TEMPLATE_WAITLIST=
SENDGRID_TEMPLATE_ROADMAP=

# ─── Email — Mailgun (alternative to SendGrid) ────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ─── Admin Protection ─────────────────────────────────────────
ADMIN_ACCESS_KEY=

# ─── Storage — Local / S3 / Cloudflare R2 ─────────────────────
STORAGE_PROVIDER=local
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Cloudflare R2 (S3-compatible)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=

# ─── Cloudflare (CDN / DNS / Domain API) ─────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Domain & Registrar ───────────────────────────────────────
DOMAIN_AFFILIATE_URL=https://namecheap.pxf.io/pen2pro
NAMECHEAP_AFFILIATE_ID=

# ─── Document Signing ─────────────────────────────────────────
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_ACCOUNT_ID=
PANDADOC_API_KEY=

# ─── Accounting ───────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
WAVE_API_KEY=

# ─── Automation / Webhooks ────────────────────────────────────
ZAPIER_WEBHOOK_URL=
MAKE_WEBHOOK_URL=

# ─── Tracking / Ads ───────────────────────────────────────────
META_PIXEL_ID=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=

# ─── Affiliate Links ──────────────────────────────────────────
AFFILIATE_LLC_URL=https://www.zenbusiness.com/?affiliate=pen2pro
AFFILIATE_BANKING_URL=https://mercury.com/?r=pen2pro
AFFILIATE_CREDIT_URL=https://nav.com/?affiliate=pen2pro
AFFILIATE_FUNDING_URL=https://fundbox.com/?affiliate=pen2pro
