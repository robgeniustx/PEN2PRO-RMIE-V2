AFFILIATE_BOOKKEEPING_URL=https://wave.com/?affiliate=pen2pro
AFFILIATE_PAYMENT_URL=https://stripe.com/?affiliate=pen2pro
AFFILIATE_CRM_URL=https://hubspot.com/?affiliate=pen2pro
AFFILIATE_INSURANCE_URL=https://nextinsurance.com/?affiliate=pen2pro
AFFILIATE_MARKETING_URL=https://mailchimp.com/?affiliate=pen2pro

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BLUEPRINT_PER_HOUR=5

# ─── Feature Flags ────────────────────────────────────────────
PAYMENTS_LIVE=false
VOICE_AGENT_ENABLED=true
WEBSITE_BUILDER_ENABLED=true
COMMAND_CENTER_ENABLED=true
